# 数据库配置
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=你的MySQL密码
DB_NAME=travel_agent

# JWT 密钥
SECRET_KEY=你的自定义密钥

# 通义千问 API Key（在 https://dashscope.console.aliyun.com/ 申请）
DASHSCOPE_API_KEY=sk-你的Key

# Tavily 搜索 API Key（在 https://tavily.com/ 申请）
TAVILY_API_KEY=tvly-你的Key

# ====== 天气 API ======
# 和风天气: https://dev.qweather.com/
# OpenWeatherMap: https://openweathermap.org/api
WEATHER_API_KEY=

# ====== 汇率 API ======
# Open Exchange Rates: https://openexchangerates.org/
# 留空则使用内置固定汇率
OPEN_EXCHANGE_KEY=

# ====== 高德地图 API ======
# 注册地址: https://lbs.amap.com/
# 创建应用后选择「Web服务」类型，获取 Key
# 免费额度: 30万次/日（个人开发者足够）
AMAP_API_KEY=